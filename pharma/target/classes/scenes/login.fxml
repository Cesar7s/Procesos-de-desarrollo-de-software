<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane id="AnchorPane" fx:id="loginPanel" prefHeight="353.0" prefWidth="517.0" style="-fx-background-color: #badeea;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.pharma.controllers.LoginController">
   <children>
      <Button fx:id="btnIngresar" layoutX="52.0" layoutY="257.0" mnemonicParsing="false" onAction="#switchToSecondary" prefHeight="38.0" prefWidth="182.0" style="-fx-background-color: #208acb; -fx-background-radius: 12;" text="INGRESAR" textFill="#0b0a0a">
         <font>
            <Font name="Bodoni MT" size="18.0" />
         </font>
      </Button>
      <TextField fx:id="txtUsuario" alignment="TOP_LEFT" layoutX="45.0" layoutY="109.0" promptText="Usuario" style="-fx-background-color: transparent; -fx-border-color: transparent transparent black transparent; -fx-border-width: 0 0 3 0; -fx-padding: 9 5 0 30;">
         <cursor>
            <Cursor fx:constant="TEXT" />
         </cursor>
         <font>
            <Font size="18.0" />
         </font>
      </TextField>
      <PasswordField fx:id="txtContrasena" layoutX="45.0" layoutY="177.0" promptText="Contrasena" style="-fx-background-color: transparent; -fx-border-color: transparent transparent black transparent; -fx-border-width: 0 0 3 0; -fx-padding: 9 5 0 30;">
         <font>
            <Font size="18.0" />
         </font>
      </PasswordField>
      <ImageView fitHeight="28.0" fitWidth="28.0" layoutX="43.0" layoutY="112.0" nodeOrientation="INHERIT" pickOnBounds="true">
         <image>
            <Image url="@/images/usuario.png" />
         </image>
      </ImageView>
      <ImageView fitHeight="219.0" fitWidth="230.0" layoutX="286.0" layoutY="54.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@/images/logo.png" />
         </image>
      </ImageView>
      <ImageView fitHeight="38.0" fitWidth="38.0" layoutX="40.0" layoutY="173.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@/images/candado.png" />
         </image>
      </ImageView>
   </children>
</AnchorPane>
